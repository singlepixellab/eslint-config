{
  "name": "@singlepixellab/eslint-config",
  "version": "2.2.1",
  "description": "The ESLint rules and configs used by Single Pixel Lab",
  "author": "Single Pixel Lab",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "lint"
  ],
  "license": "MIT",
  "private": false,
  "homepage": "https://github.com/singlepixellab/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/singlepixellab/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/singlepixellab/eslint-config/issues"
  },
  "type": "module",
  "prettier": "@singlepixellab/prettier-config",
  "files": [
    "index.js",
    "eslint.config.js",
    "rules"
  ],
  "exports": {
    ".": {
      "import": "./index.js"
    },
    "./core": {
      "import": "./rules/core.js"
    },
    "./ignores": {
      "import": "./rules/ignores.js"
    },
    "./imports": {
      "import": "./rules/imports.js"
    },
    "./jsdoc": {
      "import": "./rules/jsdoc.js"
    },
    "./prettier": {
      "import": "./rules/prettier.js"
    },
    "./react": {
      "import": "./rules/react.js"
    },
    "./styles": {
      "import": "./rules/styles.js"
    },
    "./typescript": {
      "import": "./rules/typescript.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "eslint": ">= 9",
    "typescript": ">=3.3.1"
  },
  "scripts": {
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "lint": "eslint .",
    "inspect": "eslint --inspect-config"
  },
  "devDependencies": {
    "@singlepixellab/prettier-config": "^1.2.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.58.2"
  }
}
